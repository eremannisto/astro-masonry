---
import { ClientRouter } from "astro:transitions"
import { Masonry } from "@mannisto/astro-masonry/components"
import Card from "../../components/Card.astro"
import Circle from "../../components/Circle.astro"
import Layout from "../../components/Layout.astro"
---

<Layout title="Transitions B">
  <ClientRouter slot="head" />
  <nav>
    <a href="/transitions/" data-testid="nav-to-a">← Go to A</a>
  </nav>
  <h1>Transitions B</h1>
  <Masonry columns={2} gap="1rem" aria-label="Transitions B grid">
    <Card color="green" height={180} testId="tb-item-1"><Circle color="green">1</Circle></Card>
    <Card color="green" height={120} testId="tb-item-2"><Circle color="green">2</Circle></Card>
    <Card color="green" height={220} testId="tb-item-3"><Circle color="green">3</Circle></Card>
    <Card color="green" height={160} testId="tb-item-4"><Circle color="green">4</Circle></Card>
  </Masonry>
</Layout>
