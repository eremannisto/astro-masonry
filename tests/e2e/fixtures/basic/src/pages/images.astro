---
import { Masonry } from "@mannisto/astro-masonry/components"
import "../styles/global.css"
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Images</title>
  </head>
  <body>
    <main>
      <h1>Image cards</h1>
      <Masonry columns={2} gap="1rem" aria={{ label: "Image masonry grid" }}>
        <!-- No image — layout should run immediately for this item -->
        <div class="card card--pink" data-testid="item-no-img" style="height: 150px;">
          No image
        </div>

        <!-- Working image -->
        <div class="card card--pink card--image" data-testid="item-img-ok-1" style="height: 200px;">
          <img src="/tile.svg" alt="Tile" data-testid="img-ok-1" />
        </div>

        <!-- Broken image — error event must not block layout -->
        <div class="card card--pink card--image" data-testid="item-img-broken" style="height: 150px;">
          <img src="/missing.png" alt="Missing" data-testid="img-broken" />
        </div>

        <!-- Second working image -->
        <div class="card card--pink card--image" data-testid="item-img-ok-2" style="height: 100px;">
          <img src="/tile.svg" alt="Tile" data-testid="img-ok-2" />
        </div>
      </Masonry>
    </main>
  </body>
</html>
