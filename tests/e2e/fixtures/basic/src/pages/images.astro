---
import { Image } from "astro:assets"
import { Masonry } from "@mannisto/astro-masonry/components"
import img1 from "../assets/image-1.jpg"
import img2 from "../assets/image-2.jpg"
import img3 from "../assets/image-3.jpg"
import img4 from "../assets/image-4.jpg"
import img5 from "../assets/image-5.jpg"
import img6 from "../assets/image-6.jpg"
import img7 from "../assets/image-7.jpg"
import img8 from "../assets/image-8.jpg"
import Card from "../components/Card.astro"
import Layout from "../components/Layout.astro"

const images = [img1, img2, img3, img4, img5, img6, img7, img8]
---

<Layout title="Images">
  <h1>Image cards</h1>
  <Masonry autoColumns="300px" aria-label="Image masonry grid">
    {images.map((src, i) => (
      <Image
        src={src}
        width={src.width}
        height={src.height}
        alt=""
        data-testid={`item-img-${i + 1}`}
        style="display: block; width: 100%; height: auto; border-radius: 8px;"
      />
    ))}

    <!-- Broken image — error must not block layout from completing -->
    <Card color="red" height={260} testId="item-img-broken" image>
      <img src="/missing.png" alt="Missing" data-testid="img-broken" />
    </Card>
  </Masonry>
</Layout>
