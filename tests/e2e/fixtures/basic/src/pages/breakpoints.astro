---
import { Masonry } from "@mannisto/astro-masonry/components"
import "../styles/global.css"

// 1 column below 480px, 2 columns from 480px, 3 columns from 768px
const items = [
  { id: 1, height: 200 },
  { id: 2, height: 100 },
  { id: 3, height: 150 },
  { id: 4, height: 250 },
  { id: 5, height: 100 },
  { id: 6, height: 200 },
  { id: 7, height: 150 },
  { id: 8, height: 100 },
]
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Breakpoints — responsive columns</title>
  </head>
  <body>
    <main>
      <h1>Responsive columns (breakpoints)</h1>
      <Masonry
        columns={1}
        breakpoints={{ 480: 2, 768: 3 }}
        gap="1rem"
        aria={{ label: "Responsive masonry grid" }}
      >
        {items.map((item) => (
          <div
            class="card card--green"
            data-testid={`item-${item.id}`}
            style={`height: ${item.height}px;`}
          >
            Item {item.id}
          </div>
        ))}
      </Masonry>
    </main>
  </body>
</html>
